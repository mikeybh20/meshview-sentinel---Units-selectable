# Copy to .env and fill in values
# NOTE: Keys can also be set from the GUI (sidebar → AI Settings)
# GUI-set keys persist to .ai-config.json and override these .env values.

# Anthropic API key (Claude)
ANTHROPIC_API_KEY=

# Gemini API key (Google)
GEMINI_API_KEY=

# API server port
API_PORT=3001

# Enable auto-discovery of USB LoRa radios (set to true in Docker)
SERIAL_AUTO_DISCOVER=true

# Override serial port manually (optional — auto-discover handles this)
# SERIAL_PORT=/dev/ttyUSB0
